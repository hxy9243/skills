{
  "notebook_root": "/absolute/path/to/notebook",
  "include_roots": [
    ".",
    "Projects"
  ],
  "exclude_globs": [
    "_WIKI/**",
    ".obsidian/**",
    "Templates/**",
    "Archive/**"
  ],
  "generated_root": "/absolute/path/to/notebook/_WIKI",
  "category_overrides": {
    "00_Inbox/Some Note.md": [
      "Computer Science",
      "AI Systems",
      "Agents"
    ]
  },
  "category_prefix_overrides": {
    "20_Subjects/Computer Science/Computer Systems/Distributed Systems": [
      "Computer Science",
      "Computer Systems",
      "Distributed Systems"
    ]
  },
  "category_rules": [
    {
      "keywords": ["dspy", "gepa", "mipro", "teleprompt", "prompt-optimization", "prompt", "coding-agent", "ai-agent", "agent-framework", "skills"],
      "category": ["Computer Science", "Artificial Intelligence", "AI Agents"]
    },
    {
      "keywords": ["agent", "assistant", "tool", "workflow", "automation"],
      "category": ["Computer Science", "Artificial Intelligence", "AI Systems", "Agents"]
    },
    {
      "keywords": ["distributed", "database", "replication", "consensus", "scheduler", "cluster"],
      "category": ["Computer Science", "Computer Systems", "Distributed Systems"]
    }
  ],
  "search": {
    "lexical_limit": 8
  }
}

Place this file at `_WIKI/config.json` for the notebook-specific default configuration.
Use `category_overrides` for notebook-specific placements you want to keep stable across rebuilds.
Use `category_prefix_overrides` for folder-level placement rules that should apply to many notes.
Prefer topic-based override branches over generic buckets like `Research`, `Papers`, or `General`.
